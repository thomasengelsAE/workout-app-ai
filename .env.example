# PostgreSQL
DATABASE_URL="postgresql://fitness:fitness@localhost:5433/fitness?schema=public"

# AWS S3 / MinIO (progress photos)
S3_BUCKET="fitness"
S3_REGION="us-east-1"
# Uncomment for local MinIO:
# S3_ENDPOINT="http://localhost:9002"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# OpenAI (workout generation & photo analysis)
OPENAI_API_KEY=""

# Keycloak / NextAuth
AUTH_SECRET=""              # generate: openssl rand -base64 32
AUTH_KEYCLOAK_ID=""         # Keycloak client ID
AUTH_KEYCLOAK_SECRET=""     # Keycloak client secret
AUTH_KEYCLOAK_ISSUER=""     # e.g. http://localhost:8081/realms/fitness

# App
NEXTAUTH_URL="http://localhost:3001"

# Playwright E2E (optional override)
PLAYWRIGHT_BASE_URL="http://localhost:3001"
