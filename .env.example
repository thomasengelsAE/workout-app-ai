# PostgreSQL
DATABASE_URL="postgresql://fitness:fitness@localhost:5433/fitness?schema=public"

# Google Cloud Storage (progress photos)
GCS_BUCKET="fitness"
# Path to GCP service account JSON key file.
# For local dev with fake-gcs-server, leave blank (emulator runs unauthenticated).
# For production on GCP, use Workload Identity instead and omit this variable.
GCS_KEY_FILE_PATH=""
# Local dev only — points the GCS SDK at the fake-gcs-server emulator.
# Uncomment when running docker compose:
# STORAGE_EMULATOR_HOST="http://localhost:4443"

# OpenAI (workout generation & photo analysis)
OPENAI_API_KEY=""

# Keycloak / NextAuth
AUTH_SECRET=""              # generate: openssl rand -base64 32
AUTH_KEYCLOAK_ID=""         # Keycloak client ID
AUTH_KEYCLOAK_SECRET=""     # Keycloak client secret
AUTH_KEYCLOAK_ISSUER=""     # e.g. http://localhost:8081/realms/fitness

# App
NEXTAUTH_URL="http://localhost:3001"

# Playwright E2E (optional override)
PLAYWRIGHT_BASE_URL="http://localhost:3001"
